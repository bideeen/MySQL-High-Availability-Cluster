[mysqld]

# ─── IDENTITY ───────────────────────────────────────────
# NOTE: server-id will be overridden per container via
# environment variable in the workflow (2 = replica1, 3 = replica2)
server-id                = 2
report_host              = mysql-replica

# ─── BINARY LOG ─────────────────────────────────────────
log_bin                  = mysql-bin
binlog_format            = ROW
binlog_row_image         = FULL
expire_logs_days         = 7
max_binlog_size          = 100M

# ─── GTID (must match primary settings exactly) ─────────
gtid_mode                = ON
enforce_gtid_consistency = ON
log_slave_updates        = ON

# ─── RELAY LOG (how replica receives changes) ────────────
relay_log                = relay-bin
relay_log_purge          = ON
relay_log_recovery       = ON

# ─── READ ONLY (replicas must not accept writes) ─────────
read_only                = ON
super_read_only          = ON

# ─── REPLICATION SAFETY ──────────────────────────────────
sync_binlog              = 1
innodb_flush_log_at_trx_commit = 1

# ─── PERFORMANCE (tuned for CI runner) ───────────────────
innodb_buffer_pool_size  = 128M
innodb_log_file_size     = 64M
innodb_flush_method      = O_DIRECT

# ─── NETWORK ─────────────────────────────────────────────
bind-address             = 0.0.0.0
port                     = 3306